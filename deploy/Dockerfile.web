# Sirve el export HTML5 de Godot detrás de Traefik/RenaceNet
FROM nginx:1.27-alpine

COPY deploy/nginx-web.conf /etc/nginx/conf.d/default.conf

# Quitar "Welcome to nginx!" de la imagen base
RUN rm -rf /usr/share/nginx/html/*

COPY export/web/ /usr/share/nginx/html/
COPY deploy/privacy.html /usr/share/nginx/html/privacy.html
COPY LEGAL.md /usr/share/nginx/html/LEGAL.md
COPY PRIVACY.md /usr/share/nginx/html/PRIVACY.md

# Fallar el build si aún no hay export real (evita servir el placeholder)
RUN set -e; \
    if ! ls /usr/share/nginx/html/*.wasm >/dev/null 2>&1; then \
      echo "ERROR: falta export Web Godot (.wasm). En VPS: FORCE_GODOT_EXPORT=1 ./deploy.sh update"; \
      exit 1; \
    fi; \
    if [ ! -f /usr/share/nginx/html/index.html ] || grep -q 'Falta el export Web' /usr/share/nginx/html/index.html; then \
      echo "ERROR: index.html es placeholder, no el export de Godot."; \
      exit 1; \
    fi

EXPOSE 80
