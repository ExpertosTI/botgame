# Sirve el export HTML5 de Godot detrás de Traefik/RenaceNet
FROM nginx:1.27-alpine

COPY deploy/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY export/web/ /usr/share/nginx/html/

# Si aún no hay export, página placeholder
RUN if [ ! -f /usr/share/nginx/html/index.html ]; then \
      printf '%s\n' \
        '<!doctype html><html><head><meta charset="utf-8"><title>Bestia vs Robots</title></head>' \
        '<body style="font-family:system-ui;background:#0b1020;color:#e8eefc;display:grid;place-items:center;min-height:100vh">' \
        '<div><h1>Bestia vs Robots</h1><p>Export Web pendiente. Genera <code>export/web/</code> en Godot y redespliega.</p></div>' \
        '</body></html>' > /usr/share/nginx/html/index.html; \
    fi

EXPOSE 80
