# Landing promocional en / + export Godot HTML5 en /play/
FROM nginx:1.27-alpine

COPY deploy/nginx-web.conf /etc/nginx/conf.d/default.conf

RUN rm -rf /usr/share/nginx/html/*

# Juego Godot (no pisa el index de la landing)
COPY export/web/ /usr/share/nginx/html/play/

# Homepage landing (+ media staged por scripts/stage_landing_media.sh)
COPY deploy/landing/index.html /usr/share/nginx/html/index.html
COPY deploy/landing/landing.css /usr/share/nginx/html/landing.css
COPY deploy/landing/landing.js /usr/share/nginx/html/landing.js
COPY deploy/landing/media/ /usr/share/nginx/html/media/

COPY deploy/privacy.html /usr/share/nginx/html/privacy.html
COPY LEGAL.md /usr/share/nginx/html/LEGAL.md
COPY PRIVACY.md /usr/share/nginx/html/PRIVACY.md

RUN set -e; \
    if ! ls /usr/share/nginx/html/play/*.wasm >/dev/null 2>&1; then \
      echo "ERROR: falta export Web Godot (.wasm) en /play/. En VPS: FORCE_GODOT_EXPORT=1 ./deploy.sh update"; \
      exit 1; \
    fi; \
    if [ ! -f /usr/share/nginx/html/play/index.html ] || grep -q 'Falta el export Web' /usr/share/nginx/html/play/index.html; then \
      echo "ERROR: /play/index.html no es el export de Godot."; \
      exit 1; \
    fi; \
    if [ ! -f /usr/share/nginx/html/index.html ]; then \
      echo "ERROR: falta landing index.html"; \
      exit 1; \
    fi; \
    if [ ! -f /usr/share/nginx/html/media/chadrine_keyart.png ]; then \
      echo "ERROR: falta media staging (scripts/stage_landing_media.sh)"; \
      exit 1; \
    fi

EXPOSE 80
