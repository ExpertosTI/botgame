; Engine configuration file.
; CHADRINE — juego multijugador asimétrico 3D

config_version=5

[application]

config/name="CHADRINE"
config/description="CHADRINE Hub · asimétrico, platformer, FPS y city builder. © Renace Tech."
config/version="1.3.2"
config/author="Renace Tech / Expertos TI"
run/main_scene="res://scenes/main/intro.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"
boot_splash/bg_color=Color(0.027451, 0.0431373, 0.0627451, 1)
boot_splash/image="res://assets/ui/splash_chadrine.png"
boot_splash/fullsize=false
boot_splash/use_filter=true
boot_splash/minimum_display_time=1200

[autoload]

NetworkManager="*res://autoload/network_manager.gd"
GameManager="*res://autoload/game_manager.gd"
InputManager="*res://autoload/input_manager.gd"
CombatFx="*res://autoload/combat_fx.gd"
ProgressionManager="*res://autoload/progression_manager.gd"
SettingsManager="*res://autoload/settings_manager.gd"
MatchStats="*res://autoload/match_stats.gd"
AudioDirector="*res://autoload/audio_director.gd"
ModeRouter="*res://autoload/mode_router.gd"
CharacterCatalog="*res://autoload/character_catalog.gd"
PresenceHttp="*res://autoload/presence_http.gd"
OnlineInvite="*res://autoload/online_invite.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

