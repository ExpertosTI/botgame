; Engine configuration file.
; Bestia vs Robots — juego multijugador asimétrico 3D

config_version=5

[application]

config/name="Bestia vs Robots"
config/description="Juego multijugador asimétrico: robots exploradores vs bestia mecánica"
run/main_scene="res://scenes/main/menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

NetworkManager="*res://autoload/network_manager.gd"
GameManager="*res://autoload/game_manager.gd"
InputManager="*res://autoload/input_manager.gd"
CombatFx="*res://autoload/combat_fx.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

